# One-off diagnostic — runs ONLY when you trigger it manually.
# File location:  .github/workflows/probe.yml

name: Probe blocked newspapers

on:
  workflow_dispatch:   # manual trigger only; no schedule

jobs:
  probe:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install -r requirements.txt
      - run: python probe.py
